{
  "realm": "portops",
  "displayName": "PortOps Maritime",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 3600,

  "roles": {
    "realm": [
      { "name": "ADMIN",                  "description": "Acceso total al sistema sin restricciones de puerto ni dominio" },
      { "name": "VIEWER",                 "description": "Acceso de solo lectura a datos permitidos por su puerto o ámbito" },
      { "name": "PORT_ADMIN",             "description": "Gestión operativa y administrativa del puerto (infraestructura, recursos, concesiones)" },
      { "name": "PORT_OPERATOR",          "description": "Ejecución de operaciones portuarias (coordinación de atraques, recursos y flujo operativo)" },
      { "name": "MARITIME_AUTHORITY",     "description": "Autoriza entrada/salida de buques y regula la navegación en el puerto" },
      { "name": "PILOT",                  "description": "Asistencia técnica en maniobras de entrada/salida de buques dentro del puerto" },
      { "name": "VESSEL_CAPTAIN",         "description": "Control del propio buque y solicitud de operaciones portuarias" },
      { "name": "SHIP_AGENT",             "description": "Representación de la naviera en trámites operativos y documentales del puerto" },
      { "name": "CARRIER",               "description": "Transporte terrestre de mercancías desde y hacia el puerto" },
      { "name": "STEVEDORE",             "description": "Ejecución de carga y descarga de mercancías en operaciones portuarias" },
      { "name": "MOORING_TEAM",          "description": "Operaciones de amarre y desamarre de buques" },
      { "name": "CUSTOMS_OFFICER",       "description": "Autoridad aduanera para inspección y control de mercancías" },
      { "name": "BORDER_CONTROL",        "description": "Control de acceso de personas y documentación en el puerto" },
      { "name": "EMERGENCY_COORDINATOR", "description": "Gestión y coordinación de emergencias en el entorno portuario" },
      { "name": "RESCUE_TEAM",           "description": "Ejecución de operaciones de rescate marítimo y portuario" },
      { "name": "ENVIRONMENTAL_RESPONSE","description": "Gestión de incidentes ambientales (derrames, contaminación)" }
    ]
  },



  "clients": [
    {
      "clientId": "portops-api",
      "name": "PortOps API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "portops-app",
      "name": "PortOps App",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8090/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8090"
      ],
      "protocolMappers": [
        {
          "name": "roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "role",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    }
  ],

